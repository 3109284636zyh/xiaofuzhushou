.chat-card { padding: 36rpx; margin-bottom: 24rpx; }
.hero-pill { color: #fff; background: rgba(255,255,255,.22); }
.chat-title { margin-top: 20rpx; font-size: 44rpx; line-height: 1.18; font-weight: 900; }
.form-card { display: grid; gap: 18rpx; }
.textarea { height: 260rpx; width: 100%; }
.reply-card { margin-top: 24rpx; }
.section-head { display: flex; justify-content: space-between; align-items: center; font-weight: 800; margin-bottom: 18rpx; }
.fallback-hint { margin-top: 18rpx; color: #B45309; background: rgba(245,158,11,.12); padding: 16rpx; border-radius: 16rpx; }
