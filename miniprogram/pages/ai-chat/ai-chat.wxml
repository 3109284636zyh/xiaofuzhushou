<view class="container ai-chat-page">
  <view class="card chat-card primary-gradient">
    <view class="pill hero-pill">平台内安全回复</view>
    <view class="chat-title">把客户问题改写成可复制的成交回复</view>
  </view>
  <view class="card form-card">
    <textarea class="input-box textarea" value="{{prompt}}" placeholder="粘贴客户问题或聊天上下文" bindinput="onPromptInput" />
    <button class="btn-primary" loading="{{loading}}" bindtap="submit">生成回复</button>
  </view>
  <view wx:if="{{reply}}" class="card reply-card">
    <view class="section-head"><text>可复制回复</text><button size="mini" bindtap="copyReply">复制</button></view>
    <view class="copy-text">{{reply.text}}</view>
    <view wx:if="{{reply.fallback}}" class="fallback-hint">DeepSeek 未返回安全内容，已启用兜底话术。</view>
  </view>
</view>
