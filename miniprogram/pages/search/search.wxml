<view class="safe-page container search-page">
  <view class="page-safe-top" style="height: {{topSpacerHeight}}rpx;"></view>
  <view class="card search-hero"><view class="pill title-with-icon"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/search.png" mode="aspectFit" /><text>全局搜索</text></view><view class="search-title">产品、知识、教程和历史记录一起搜</view><view class="search-row"><view class="search-input-wrap"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/search.png" mode="aspectFit" /><input class="search-input" value="{{keyword}}" placeholder="输入关键词" bindinput="onKeywordInput" confirm-type="search" bindconfirm="search" /></view><button class="btn-primary search-button" loading="{{loading}}" bindtap="search"><view class="button-content"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/arrow-right.png" mode="aspectFit" /><text>搜索</text></view></button></view></view>
  <view wx:if="{{searched && results.length === 0}}" class="empty-state title-with-icon"><image class="ui-icon ui-icon-md" src="/assets/icons/ui/empty.png" mode="aspectFit" /><text>没有找到相关内容，可以换个关键词试试</text></view>
  <view wx:for="{{results}}" wx:key="targetId" class="card result-card" bindtap="openResult" data-item="{{item}}"><view class="row-with-icon"><view class="ui-icon-badge"><image class="ui-icon ui-icon-md" src="{{item.iconPath}}" mode="aspectFit" /></view><view class="icon-label"><view class="result-type">{{item.type}}</view><view class="list-title">{{item.title}}</view><view class="muted">{{item.summary}}</view></view><image class="ui-icon ui-icon-sm result-arrow" src="/assets/icons/ui/arrow-right.png" mode="aspectFit" /></view></view>
</view>
