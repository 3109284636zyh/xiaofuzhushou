<view class="safe-page container plan-page">
  <view class="page-safe-top" style="height: {{topSpacerHeight}}rpx;"></view>
  <view class="card form-card"><view class="pill title-with-icon"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/plan.png" mode="aspectFit" /><text>方案生成器</text></view><view class="page-title">输出页面规划、功能清单、周期和报价说明</view><view class="field-with-icon"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/globe.png" mode="aspectFit" /><input class="field-input" value="{{form.industry}}" placeholder="行业，例如：机械设备" data-field="industry" bindinput="onInput" /></view><view class="field-with-icon"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/budget.png" mode="aspectFit" /><input class="field-input" value="{{form.budget}}" placeholder="预算，例如：8000" data-field="budget" bindinput="onInput" /></view><view class="field-with-icon"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/message.png" mode="aspectFit" /><textarea class="textarea" value="{{form.requirements}}" placeholder="功能需求，例如：展示产品和案例，方便客户咨询" data-field="requirements" bindinput="onInput" /></view><button class="btn-primary" loading="{{loading}}" bindtap="submit"><view class="button-content"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/lightning.png" mode="aspectFit" /><text>生成建站方案</text></view></button></view>
  <view wx:if="{{result}}" class="card result-card"><view class="result-title title-with-icon"><image class="ui-icon ui-icon-md" src="/assets/icons/ui/home-service.png" mode="aspectFit" /><text>{{result.siteType}}</text></view><view class="muted title-with-icon"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/price.png" mode="aspectFit" /><text>{{result.priceRange}} · {{result.durationDays}} 天</text></view><view class="section-title title-with-icon"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/plan.png" mode="aspectFit" /><text>页面规划</text></view><view class="chip-row"><text wx:for="{{result.pages}}" wx:key="*this" class="pill page-chip">{{item}}</text></view><view class="section-title title-with-icon"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/feature.png" mode="aspectFit" /><text>功能清单</text></view><view wx:for="{{result.features}}" wx:key="*this" class="feature-item row-with-icon"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/check.png" mode="aspectFit" /><text>{{item}}</text></view><view class="copy-text proposal row-with-icon"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/document.png" mode="aspectFit" /><text>{{result.proposal}}</text></view><button class="btn-primary" bindtap="copyPlan"><view class="button-content"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/copy.png" mode="aspectFit" /><text>复制方案</text></view></button></view>
</view>
