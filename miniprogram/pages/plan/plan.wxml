<view class="container plan-page">
  <view class="card form-card">
    <view class="pill">方案生成器</view>
    <view class="page-title">输出页面规划、功能清单、周期和报价说明</view>
    <input class="input-box" value="{{form.industry}}" placeholder="行业，例如：机械设备" data-field="industry" bindinput="onInput" />
    <input class="input-box" value="{{form.budget}}" placeholder="预算，例如：8000" data-field="budget" bindinput="onInput" />
    <textarea class="input-box textarea" value="{{form.requirements}}" placeholder="功能需求，例如：展示产品和案例，方便客户咨询" data-field="requirements" bindinput="onInput" />
    <button class="btn-primary" loading="{{loading}}" bindtap="submit">生成建站方案</button>
  </view>

  <view wx:if="{{result}}" class="card result-card">
    <view class="result-title">{{result.siteType}}</view>
    <view class="muted">{{result.priceRange}} · {{result.durationDays}} 天</view>
    <view class="section-title">页面规划</view>
    <view class="chip-row"><text wx:for="{{result.pages}}" wx:key="*this" class="pill page-chip">{{item}}</text></view>
    <view class="section-title">功能清单</view>
    <view wx:for="{{result.features}}" wx:key="*this" class="feature-item">{{item}}</view>
    <view class="copy-text proposal">{{result.proposal}}</view>
    <button class="btn-primary" bindtap="copyPlan">复制方案</button>
  </view>
</view>
