.top-card { margin-bottom: 24rpx; padding: 36rpx; }
.hero-pill { color: #fff; background: rgba(255,255,255,.22); }
.tool-title { margin-top: 20rpx; font-size: 42rpx; font-weight: 900; line-height: 1.22; }
.tool-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.tool-card { text-align: center; min-height: 176rpx; padding: 22rpx 12rpx; }
.tool-icon { margin: 0 auto; }
.tool-name { margin: 10rpx 0 6rpx; font-weight: 800; font-size: 26rpx; }
.section-head { display: flex; justify-content: space-between; align-items: center; font-weight: 800; margin-bottom: 18rpx; }
.smart-list { display: grid; gap: 16rpx; }
.smart-card { border-left: 8rpx solid #1677FF; }
.result-card { margin-top: 24rpx; }
.result-row { display: flex; justify-content: space-between; padding: 14rpx 0; border-bottom: 1rpx solid rgba(22,119,255,.10); }
.smart-card .tool-name { margin-top: 0; }
.result-row .row-with-icon { flex: 1; }
.result-row > text { flex-shrink: 0; color: #1D2738; font-weight: 700; }
