.hero-card { margin-bottom: 24rpx; }
.page-title { margin: 18rpx 0 24rpx; font-size: 42rpx; line-height: 1.22; font-weight: 900; letter-spacing: -1rpx; }
.question { width: 100%; height: 180rpx; margin-bottom: 18rpx; }
.reply-card { margin: 24rpx 0; }
.section-head { display: flex; justify-content: space-between; align-items: center; font-weight: 800; margin-bottom: 18rpx; }
.category-scroll { white-space: nowrap; margin-bottom: 18rpx; }
.category-row { display: flex; gap: 14rpx; }
.category-chip { display: inline-flex; padding: 16rpx 24rpx; border-radius: 999rpx; background: rgba(255,255,255,.88); color: #667085; margin-right: 14rpx; }
.category-chip.active { background: linear-gradient(135deg, #1677FF, #6C63FF); color: #fff; }
.article-card { margin-bottom: 16rpx; }
.tags { margin-top: 12rpx; color: #1677FF; font-size: 24rpx; }
