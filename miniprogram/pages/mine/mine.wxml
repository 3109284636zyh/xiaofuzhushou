<view class="safe-page container mine-page">
  <view class="page-safe-top" style="height: {{topSpacerHeight}}rpx;"></view>
  <view class="card profile-card primary-gradient"><view class="avatar">福</view><view><view class="profile-title title-with-icon"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/profile.png" mode="aspectFit" /><text>AI小福工作台</text></view><view class="profile-sub">无注册 · 无付费 · 后端安全托管 API</view></view></view>
  <view class="section-title title-with-icon"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/shield.png" mode="aspectFit" /><text>配置状态</text></view>
  <view class="card status-card"><view wx:for="{{statusRows}}" wx:key="label" class="status-row"><view class="row-with-icon"><image class="ui-icon ui-icon-sm" src="{{item.iconPath}}" mode="aspectFit" /><text>{{item.label}}</text></view><text wx:if="{{item.pill}}" class="pill">{{item.value}}</text><text wx:else>{{item.value}}</text></view></view>
  <view class="section-title title-with-icon"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/menu.png" mode="aspectFit" /><text>常用入口</text></view>
  <view class="menu-list card"><view wx:for="{{menuItems}}" wx:key="label" class="menu-item" bindtap="openMenu" data-action="{{item.action}}"><view class="row-with-icon"><image class="ui-icon ui-icon-sm" src="{{item.iconPath}}" mode="aspectFit" /><text>{{item.label}}</text></view><image class="ui-icon ui-icon-sm menu-arrow" src="/assets/icons/ui/arrow-right.png" mode="aspectFit" /></view></view>
  <view wx:if="{{listTitle}}" class="section-title title-with-icon"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/history.png" mode="aspectFit" /><text>{{listTitle}}</text></view>
  <view wx:for="{{records}}" wx:key="id" class="card record-card row-with-icon"><view class="ui-icon-badge"><image class="ui-icon ui-icon-sm" src="/assets/icons/ui/document.png" mode="aspectFit" /></view><view class="icon-label"><view class="list-title">{{item.titleSnapshot || item.title}}</view><view class="muted">{{item.recordType}} · {{item.createdAt}}</view></view></view>
</view>
