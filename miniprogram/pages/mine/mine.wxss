.profile-card { display: flex; align-items: center; gap: 22rpx; padding: 36rpx; }
.avatar { width: 92rpx; height: 92rpx; border-radius: 28rpx; display: grid; place-items: center; background: rgba(255,255,255,.22); color: #fff; font-size: 42rpx; font-weight: 900; }
.profile-title { font-size: 38rpx; font-weight: 900; }
.profile-sub { margin-top: 8rpx; opacity: .86; font-size: 24rpx; }
.status-card { display: grid; gap: 18rpx; }
.status-row { display: flex; justify-content: space-between; align-items: center; }
.menu-list { padding: 10rpx 28rpx; }
.menu-item { padding: 24rpx 0; border-bottom: 1rpx solid rgba(22,119,255,.10); }
.menu-item:last-child { border-bottom: 0; }
.record-card { margin-bottom: 14rpx; }
